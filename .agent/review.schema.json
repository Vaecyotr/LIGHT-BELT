{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LIGHT-BELT Agent Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "summary",
    "blockers",
    "high",
    "medium",
    "required_actions"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "high": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "medium": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "required_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "file",
        "description",
        "required_fix"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "required_fix": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
